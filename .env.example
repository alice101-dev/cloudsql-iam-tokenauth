# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored on purpose — never commit real hosts or identities.
# ---------------------------------------------------------------------------

# Database connection
DB_HOST=10.0.0.5                 # Cloud SQL private IP (or 127.0.0.1 when using the Auth Proxy)
DB_PORT=5432
DB_USER=alice@example.com        # Your IAM user (no password — the token is fetched at runtime)
DB_NAME=postgres

# SSL mode. Cloud SQL enforces TLS, so default to `require`.
# pgx supports: disable | require | verify-ca | verify-full
DB_SSLMODE=require

# Application
PORT=8080
